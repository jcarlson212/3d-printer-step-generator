# Copy to .env (gitignored) and fill what you use. Nothing here is required if
# you pass credentials interactively in the CLI or rely on AWS default chains.

# --- LLM providers (local runs) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# LM Studio (OpenAI-compatible local server)
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# --- AWS / Bedrock ---
AWS_REGION=us-east-1
# BEDROCK_MODEL_ID=us.anthropic.claude-opus-4-8-v1:0

# --- Email delivery (local runs) ---
# If SMTP_HOST is set, local runs email via SMTP; otherwise they save to out/deliveries/.
DELIVERY_SENDER=cad@garrychess.ai
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
